<?xml version="1.0" encoding="utf-8"?>
<!--
    Statische App-Shortcuts: per Long-Press auf das App-Icon (oder über
    Launcher, die Shortcuts anderweitig belegen können) geht es direkt in
    die Feed-Verwaltung, während das normale Öffnen der App im
    Fullscreen-Reader landet.
-->
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:shortcutId="manage_feeds"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_feeds"
        android:shortcutShortLabel="@string/shortcut_feeds_short"
        android:shortcutLongLabel="@string/action_manage_feeds">
        <!-- targetPackage muss der applicationId entsprechen – die bleibt aus
             Update-Kompatibilität bei der alten ID (siehe app/build.gradle.kts). -->
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="de.hippokratius.kvaesitsorss"
            android:targetClass="de.hippokratius.myfeed.ui.MainActivity">
            <extra
                android:name="de.hippokratius.myfeed.extra.SCREEN"
                android:value="feeds" />
        </intent>
    </shortcut>
</shortcuts>
